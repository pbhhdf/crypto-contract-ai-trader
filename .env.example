# Copy to .env on the server when real integrations are enabled.

APP_HOST=127.0.0.1
APP_PORT=8787
APP_ENV=local
APP_BASIC_AUTH_USER=
APP_BASIC_AUTH_PASSWORD=

# Docker host bind address. Keep 127.0.0.1 for local-only or Tailscale Serve.
# On a Tailscale-only server, set this to the server's Tailscale IPv4 address.
TRADER_BIND_IP=127.0.0.1

# Public market data. Default uses Binance USD-M Futures public endpoints and
# falls back to synthetic data if the exchange endpoint is unavailable.
MARKET_DATA_SOURCE=binance_public
BINANCE_FAPI_BASE=https://fapi.binance.com
HTTP_TIMEOUT_SECONDS=8
HTTP_RETRIES=2

# AI provider. Keep `rules` until you intentionally add an API key.
AI_PROVIDER=rules
AI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# AI operator chat console. This profile grants high workspace control to the
# authenticated UI; use it only behind Tailscale/private access, strong auth,
# backups, and audit review. Keep rules for offline commands, or set codex/openai
# plus OPENAI_API_KEY for model-generated file actions.
AI_OPERATOR_ENABLED=true
AI_OPERATOR_PROVIDER=rules
AI_OPERATOR_MODEL=gpt-4.1-mini
AI_OPERATOR_ALLOW_FILE_READ=true
AI_OPERATOR_ALLOW_FILE_WRITE=true
AI_OPERATOR_ALLOW_SHELL=true
AI_OPERATOR_APPLY_MODEL_FILE_ACTIONS=true
AI_OPERATOR_WORKSPACE_ROOT=.
AI_OPERATOR_MAX_READ_BYTES=80000
AI_OPERATOR_MAX_WRITE_BYTES=200000
AI_OPERATOR_MAX_SHELL_OUTPUT_BYTES=120000
AI_OPERATOR_SHELL_TIMEOUT_SECONDS=30
AI_OPERATOR_SNAPSHOT_WRITES=true
AI_OPERATOR_SNAPSHOT_DIR=data/ai_operator_snapshots
AI_OPERATOR_MAX_SNAPSHOT_BYTES=5000000
AI_OPERATOR_BACKUP_BEFORE_SHELL=true
AI_OPERATOR_SHELL_BACKUP_DIR=reports/ai_operator_backups
AI_OPERATOR_SHELL_BACKUP_TIMEOUT_SECONDS=45

# Exchange provider. Validation calls Binance /fapi/v1/order/test; placement
# mode calls real Binance testnet /fapi/v1/order only when the explicit flag is true.
EXCHANGE_PROVIDER=binance
EXCHANGE_MODE=paper
ENABLE_BINANCE_TESTNET=false
BINANCE_TESTNET_FAPI_BASE=https://testnet.binancefuture.com
BINANCE_TESTNET_WS_BASE=wss://stream.binancefuture.com
BINANCE_PLACE_TESTNET_ORDERS=false
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Live Binance USD-M Futures. Keep disabled until long testnet validation is complete.
ENABLE_BINANCE_LIVE=false
BINANCE_LIVE_FAPI_BASE=https://fapi.binance.com
BINANCE_LIVE_WS_BASE=wss://fstream.binance.com/private
BINANCE_PLACE_LIVE_ORDERS=false
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=
LIVE_TRADING_CONFIRMATION=
PRIVATE_STREAM_STALE_SECONDS=86400
EXCHANGE_RECOVERY_STALE_SECONDS=3600
EXCHANGE_ACCOUNT_SNAPSHOT_MAX_AGE_SECONDS=30
EXECUTION_MARKET_SNAPSHOT_MAX_AGE_SECONDS=60
GO_LIVE_MIN_TESTNET_DRILL_CYCLES=24
GO_LIVE_REQUIRE_ALERT_WEBHOOK=false
GO_LIVE_REQUIRE_PRIVATE_STREAM=true
GO_LIVE_MIN_WALKFORWARD_FOLDS=2
GO_LIVE_MIN_WALKFORWARD_TOTAL_RETURN_PCT=0
GO_LIVE_MIN_WALKFORWARD_POSITIVE_FOLD_RATE_PCT=50
GO_LIVE_MAX_WALKFORWARD_DRAWDOWN_PCT=10
LIVE_ARMING_MAX_SECONDS=900
LIVE_ARMING_MAX_ORDERS=1
LIVE_ATTESTATION_MAX_AGE_DAYS=30
LIVE_PILOT_MAX_WALLET_USDT=5000
BINANCE_ENFORCE_EXCHANGE_FILTERS=true
BINANCE_MAX_TIME_DRIFT_MS=1000
BINANCE_SYNC_MARGIN_TYPE_BEFORE_ORDER=true
BINANCE_TARGET_MARGIN_TYPE=ISOLATED
BINANCE_SYNC_LEVERAGE_BEFORE_ORDER=true
BINANCE_REQUIRE_ONE_WAY_POSITION_MODE=true

# External alert delivery. Keep disabled until you add private destinations.
ALERT_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
ALERT_WEBHOOK_MIN_SEVERITY=warning
ALERT_WEBHOOK_NOTIFY_RESOLVED=true
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
ALERT_TELEGRAM_ENABLED=false
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_TELEGRAM_API_BASE=https://api.telegram.org
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_SMTP_USERNAME=
ALERT_EMAIL_SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_USE_TLS=false
ALERT_EMAIL_STARTTLS=true
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# Risk limits.
MAX_LEVERAGE=3
MAX_POSITION_PCT=0.05
MAX_ORDER_NOTIONAL_USDT=1000
MAX_DAILY_LOSS_PCT=0.03
MAX_CONSECUTIVE_LOSSES=3
MAX_OPEN_POSITIONS=8
MIN_PROTECTION_REWARD_RISK_RATIO=1.0
ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
